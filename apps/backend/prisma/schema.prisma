generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  LAWYER
  SENIOR_LAWYER
  ASSOCIATE
  CLERK
  ACCOUNTANT
  CLIENT
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  INACTIVE
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum CaseType {
  CIVIL
  CRIMINAL
  FAMILY
  CORPORATE
  CONSTITUTIONAL
  REVENUE
  OTHER
}

enum HearingOutcome {
  PENDING
  ADJOURNED
  COMPLETED
  DISMISSED
  SETTLED
  WITHDRAWN
  PARTIAL
  CANCELLED
}

enum DocumentFileType {
  PDF
  IMAGE
  DOC
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  JAZZCASH
  EASYPAISA
  CHEQUE
  ONLINE
  CARD
  OTHER
}

enum ExpenseCategory {
  COURT_FEES
  FILING_FEE
  TRAVEL
  STATIONERY
  WITNESS_FEE
  CONSULTATION
  PHOTOCOPY
  NOTARY
  OTHER
}

enum ActivityType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VIEW
  EXPORT
  IMPORT
  UPLOAD
  DOWNLOAD
  PAYMENT_RECORDED
  STATUS_CHANGE
  ASSIGNMENT
  ARCHIVE
  RESTORE
}

enum TaskType {
  HEARING
  CLIENT_MEETING
  DOCUMENT_PREPARATION
  COURT_WORK
  PERSONAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Organization (tenant root)
// ---------------------------------------------------------------------------

model Organization {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @db.VarChar(255)
  slug      String             @unique @db.VarChar(100)
  phone     String?            @db.VarChar(20)
  address   String?            @db.Text
  logo      String?            @db.VarChar(500)
  status    OrganizationStatus @default(TRIAL)
  settings  Json               @default("{}")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  users         User[]         @relation("OrganizationUsers")
  clients       Client[]       @relation("OrganizationClients")
  cases         Case[]         @relation("OrganizationCases")
  hearings      Hearing[]      @relation("OrganizationHearings")
  tasks         Task[]         @relation("OrganizationTasks")
  documents     Document[]     @relation("OrganizationDocuments")
  payments      Payment[]      @relation("OrganizationPayments")
  expenses      Expense[]      @relation("OrganizationExpenses")
  activityLogs  ActivityLog[]  @relation("OrganizationActivityLogs")
  refreshTokens RefreshToken[] @relation("OrganizationRefreshTokens")
  libraryItems  LibraryItem[]  @relation("OrganizationLibraryItems")
  legalNotes    LegalNote[]    @relation("OrganizationLegalNotes")

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String    @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  role           UserRole  @default(LAWYER)
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  preferences    Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: Cascade)

  assignedCases    Case[]        @relation("CaseAssignedLawyer")
  createdCases     Case[]        @relation("CaseCreatedBy")
  updatedCases     Case[]        @relation("CaseUpdatedBy")
  createdTasks     Task[]        @relation("TaskCreator")
  uploadedDocuments Document[]   @relation("DocumentUploader")
  recordedExpenses Expense[]     @relation("ExpenseRecorder")
  recordedPayments Payment[]     @relation("PaymentRecorder")
  activityLogs     ActivityLog[] @relation("ActivityLogActor")
  refreshTokens    RefreshToken[] @relation("UserRefreshTokens")
  legalNotes       LegalNote[]   @relation("LegalNoteCreator")
  caseReferences   CaseReference[] @relation("CaseReferenceAttacher")

  @@unique([organizationId, email], name: "users_org_email_unique")
  @@index([organizationId], name: "users_organization_id_idx")
  @@index([phone], name: "users_phone_idx")
  @@map("users")
}

// ---------------------------------------------------------------------------
// Client
// ---------------------------------------------------------------------------

model Client {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  fatherName     String?  @map("father_name") @db.VarChar(100)
  cnic           String?  @db.VarChar(15)
  phone          String   @db.VarChar(20)
  whatsapp       String?  @db.VarChar(20)
  email          String?  @db.VarChar(255)
  address        String?  @db.Text
  city           String?  @db.VarChar(100)
  notes          String?  @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationClients", fields: [organizationId], references: [id], onDelete: Cascade)
  cases        Case[]       @relation("ClientCases")
  payments     Payment[]    @relation("ClientPayments")

  @@unique([organizationId, cnic], name: "clients_org_cnic_unique")
  @@unique([organizationId, phone], name: "clients_org_phone_unique")
  @@index([organizationId], name: "clients_organization_id_idx")
  @@index([cnic], name: "clients_cnic_idx")
  @@index([phone], name: "clients_phone_idx")
  @@map("clients")
}

// ---------------------------------------------------------------------------
// Case
// ---------------------------------------------------------------------------

model Case {
  id               String     @id @default(uuid()) @db.Uuid
  organizationId   String     @map("organization_id") @db.Uuid
  clientId         String     @map("client_id") @db.Uuid
  assignedLawyerId String?    @map("assigned_lawyer_id") @db.Uuid
  createdById      String?    @map("created_by_id") @db.Uuid
  updatedById      String?    @map("updated_by_id") @db.Uuid
  caseNumber       String     @map("case_number") @db.VarChar(50)
  title            String     @db.VarChar(255)
  caseType         CaseType   @default(CIVIL) @map("case_type")
  description      String?    @db.Text
  status           CaseStatus @default(OPEN)
  courtName        String?    @map("court_name") @db.VarChar(255)
  courtLocation    String?    @map("court_location") @db.VarChar(255)
  judgeName        String?    @map("judge_name") @db.VarChar(255)
  opposingParty    String?    @map("opposing_party") @db.VarChar(255)
  opposingLawyer   String?    @map("opposing_lawyer") @db.VarChar(255)
  filedDate        DateTime?  @map("filed_date") @db.Date
  closedDate       DateTime?  @map("closed_date") @db.Date
  nextHearingDate  DateTime?  @map("next_hearing_date")
  isActive         Boolean    @default(true) @map("is_active")
  metadata         Json       @default("{}")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  organization   Organization @relation("OrganizationCases", fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client       @relation("ClientCases", fields: [clientId], references: [id], onDelete: Restrict)
  assignedLawyer User?        @relation("CaseAssignedLawyer", fields: [assignedLawyerId], references: [id], onDelete: SetNull)
  createdBy      User?        @relation("CaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?        @relation("CaseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  hearings    Hearing[]   @relation("CaseHearings")
  tasks       Task[]      @relation("CaseTasks")
  documents   Document[]  @relation("CaseDocuments")
  payments    Payment[]   @relation("CasePayments")
  expenses    Expense[]   @relation("CaseExpenses")
  caseReferences CaseReference[] @relation("CaseLegalReferences")

  @@unique([organizationId, caseNumber], name: "cases_org_case_number_unique")
  @@index([organizationId], name: "cases_organization_id_idx")
  @@index([clientId], name: "cases_client_id_idx")
  @@index([caseNumber], name: "cases_case_number_idx")
  @@index([nextHearingDate], name: "cases_next_hearing_date_idx")
  @@index([organizationId, status], name: "cases_org_status_idx")
  @@map("cases")
}

// ---------------------------------------------------------------------------
// Hearing
// ---------------------------------------------------------------------------

model Hearing {
  id                    String          @id @default(uuid()) @db.Uuid
  organizationId        String          @map("organization_id") @db.Uuid
  caseId                String          @map("case_id") @db.Uuid
  scheduledDate         DateTime        @map("scheduled_date")
  actualDate            DateTime?       @map("actual_date")
  courtRoom             String?         @map("court_room") @db.VarChar(100)
  purpose               String?         @db.VarChar(255)
  judgeName             String?         @map("judge_name") @db.VarChar(255)
  outcome               HearingOutcome  @default(PENDING)
  notes                 String?         @db.Text
  nextHearingDate       DateTime?       @map("next_hearing_date")
  reminderSentAt        DateTime?       @map("reminder_sent_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationHearings", fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case         @relation("CaseHearings", fields: [caseId], references: [id], onDelete: Cascade)

  @@index([organizationId], name: "hearings_organization_id_idx")
  @@index([caseId], name: "hearings_case_id_idx")
  @@index([nextHearingDate], name: "hearings_next_hearing_date_idx")
  @@index([scheduledDate], name: "hearings_scheduled_date_idx")
  @@map("hearings")
}

// ---------------------------------------------------------------------------
// Task (agenda items — integrated into Diary view)
// ---------------------------------------------------------------------------

model Task {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  caseId         String?    @map("case_id") @db.Uuid
  createdById    String     @map("created_by_id") @db.Uuid
  title          String     @db.VarChar(255)
  description    String?    @db.Text
  date           DateTime   @db.Date
  time           String?    @db.VarChar(5)
  type           TaskType   @default(COURT_WORK)
  status         TaskStatus @default(PENDING)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationTasks", fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case?        @relation("CaseTasks", fields: [caseId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([organizationId], name: "tasks_organization_id_idx")
  @@index([caseId], name: "tasks_case_id_idx")
  @@index([date], name: "tasks_date_idx")
  @@index([organizationId, date], name: "tasks_org_date_idx")
  @@map("tasks")
}

// ---------------------------------------------------------------------------
// Document
// ---------------------------------------------------------------------------

model Document {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  caseId         String           @map("case_id") @db.Uuid
  uploadedById   String           @map("uploaded_by_id") @db.Uuid
  fileName       String           @map("file_name") @db.VarChar(255)
  storageKey     String           @map("storage_key") @db.VarChar(500)
  fileType       DocumentFileType @default(OTHER) @map("file_type")
  mimeType       String           @map("mime_type") @db.VarChar(100)
  fileSize       Int              @default(0) @map("file_size")
  category       String?          @db.VarChar(100)
  description    String?          @db.Text
  tags           String[]         @default([])
  checksum       String?          @db.VarChar(64)
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationDocuments", fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case         @relation("CaseDocuments", fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([organizationId], name: "documents_organization_id_idx")
  @@index([caseId], name: "documents_case_id_idx")
  @@map("documents")
}

// ---------------------------------------------------------------------------
// Payment
// ---------------------------------------------------------------------------

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  caseId          String        @map("case_id") @db.Uuid
  clientId        String?       @map("client_id") @db.Uuid
  recordedById    String?       @map("recorded_by_id") @db.Uuid
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("PKR") @db.VarChar(3)
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod @default(CASH)
  description     String?       @db.Text
  referenceNumber String?       @map("reference_number") @db.VarChar(100)
  dueDate         DateTime?     @map("due_date") @db.Date
  paidDate        DateTime?     @map("paid_date") @db.Date
  reminderSentAt  DateTime?     @map("reminder_sent_at")
  metadata        Json          @default("{}")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationPayments", fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case         @relation("CasePayments", fields: [caseId], references: [id], onDelete: Cascade)
  client       Client?      @relation("ClientPayments", fields: [clientId], references: [id], onDelete: SetNull)
  recordedBy   User?        @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([organizationId], name: "payments_organization_id_idx")
  @@index([caseId], name: "payments_case_id_idx")
  @@index([clientId], name: "payments_client_id_idx")
  @@index([status], name: "payments_status_idx")
  @@map("payments")
}

// ---------------------------------------------------------------------------
// Expense
// ---------------------------------------------------------------------------

model Expense {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  caseId         String          @map("case_id") @db.Uuid
  recordedById   String          @map("recorded_by_id") @db.Uuid
  category       ExpenseCategory @default(OTHER)
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          @default("PKR") @db.VarChar(3)
  description    String?         @db.Text
  expenseDate    DateTime        @map("expense_date") @db.Date
  receiptKey     String?         @map("receipt_key") @db.VarChar(500)
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationExpenses", fields: [organizationId], references: [id], onDelete: Cascade)
  case         Case         @relation("CaseExpenses", fields: [caseId], references: [id], onDelete: Cascade)
  recordedBy   User         @relation("ExpenseRecorder", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([organizationId], name: "expenses_organization_id_idx")
  @@index([caseId], name: "expenses_case_id_idx")
  @@index([category], name: "expenses_category_idx")
  @@map("expenses")
}

// ---------------------------------------------------------------------------
// Activity Log (audit trail)
// ---------------------------------------------------------------------------

model ActivityLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  activityType   ActivityType @map("activity_type")
  entityType     String?      @map("entity_type") @db.VarChar(50)
  entityId       String?      @map("entity_id") @db.Uuid
  description    String?      @db.Text
  metadata       Json         @default("{}")
  ipAddress      String?      @map("ip_address") @db.VarChar(45)
  userAgent      String?      @map("user_agent") @db.VarChar(500)
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation("OrganizationActivityLogs", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation("ActivityLogActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId], name: "activity_logs_organization_id_idx")
  @@index([userId], name: "activity_logs_user_id_idx")
  @@index([entityType, entityId], name: "activity_logs_entity_idx")
  @@index([activityType], name: "activity_logs_activity_type_idx")
  @@index([createdAt], name: "activity_logs_created_at_idx")
  @@map("activity_logs")
}

// ---------------------------------------------------------------------------
// Refresh Token (auth)
// ---------------------------------------------------------------------------

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  replacedById   String?   @map("replaced_by_id") @db.Uuid
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation("OrganizationRefreshTokens", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId], name: "refresh_tokens_organization_id_idx")
  @@index([userId], name: "refresh_tokens_user_id_idx")
  @@index([expiresAt], name: "refresh_tokens_expires_at_idx")
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Legal Research — Library (judgments, books, reference PDFs)
// ---------------------------------------------------------------------------

model LibraryItem {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String?  @map("organization_id") @db.Uuid
  title            String   @db.VarChar(500)
  citation         String?  @db.VarChar(255)
  court            String?  @db.VarChar(255)
  jurisdiction     String?  @db.VarChar(255)
  year             Int?
  category         String?  @db.VarChar(100)
  author           String?  @db.VarChar(255)
  pdfUrl           String   @map("pdf_url") @db.VarChar(500)
  totalPages       Int      @default(0) @map("total_pages")
  description      String?  @db.Text
  tags             String[] @default([])
  isSystemDocument Boolean  @default(false) @map("is_system_document")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization? @relation("OrganizationLibraryItems", fields: [organizationId], references: [id], onDelete: Cascade)
  legalNotes   LegalNote[]   @relation("LibraryItemNotes")

  @@index([organizationId], name: "library_items_organization_id_idx")
  @@index([isSystemDocument], name: "library_items_system_idx")
  @@index([court], name: "library_items_court_idx")
  @@index([category], name: "library_items_category_idx")
  @@map("library_items")
}

// ---------------------------------------------------------------------------
// Legal Research — Personal legal notes (highlighted paragraphs)
// ---------------------------------------------------------------------------

model LegalNote {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  createdById    String   @map("created_by_id") @db.Uuid
  libraryItemId  String?  @map("library_item_id") @db.Uuid
  pageNumber     Int      @map("page_number")
  selectedText   String   @map("selected_text") @db.Text
  personalNote   String?  @map("personal_note") @db.Text
  title          String   @db.VarChar(500)
  citation       String?  @db.VarChar(255)
  court          String?  @db.VarChar(255)
  tags           String[] @default([])
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization    @relation("OrganizationLegalNotes", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("LegalNoteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  libraryItem    LibraryItem?    @relation("LibraryItemNotes", fields: [libraryItemId], references: [id], onDelete: SetNull)
  caseReferences CaseReference[] @relation("LegalNoteCaseReferences")

  @@index([organizationId], name: "legal_notes_organization_id_idx")
  @@index([createdById], name: "legal_notes_created_by_id_idx")
  @@index([libraryItemId], name: "legal_notes_library_item_id_idx")
  @@index([court], name: "legal_notes_court_idx")
  @@index([citation], name: "legal_notes_citation_idx")
  @@map("legal_notes")
}

// ---------------------------------------------------------------------------
// Legal Research — Case ↔ Legal Note (many-to-many)
// ---------------------------------------------------------------------------

model CaseReference {
  id           String   @id @default(uuid()) @db.Uuid
  caseId       String   @map("case_id") @db.Uuid
  legalNoteId  String   @map("legal_note_id") @db.Uuid
  attachedById String   @map("attached_by_id") @db.Uuid
  attachedAt   DateTime @default(now()) @map("attached_at")

  case       Case      @relation("CaseLegalReferences", fields: [caseId], references: [id], onDelete: Cascade)
  legalNote  LegalNote @relation("LegalNoteCaseReferences", fields: [legalNoteId], references: [id], onDelete: Cascade)
  attachedBy User      @relation("CaseReferenceAttacher", fields: [attachedById], references: [id], onDelete: Restrict)

  @@unique([caseId, legalNoteId], name: "case_references_case_note_unique")
  @@index([caseId], name: "case_references_case_id_idx")
  @@index([legalNoteId], name: "case_references_legal_note_id_idx")
  @@map("case_references")
}
