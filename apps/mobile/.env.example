# Backend API base URL (must include /api/v1)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Notes:
# - iOS Simulator: localhost works (auto)
# - Android Emulator: localhost is auto-mapped to 10.0.2.2
# - Physical device: use your computer's LAN IP, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api/v1
#
# Ensure the backend is running: yarn backend:dev
